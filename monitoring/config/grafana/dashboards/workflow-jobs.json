        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://127.0.0.1:9103/api/counts?category=${category}&repo=${repo_filter}&workflow_name=${workflow_name}&job_type=${job_type}&search=${search:percentencode}&since=${__from:date:iso}&until=${__to:date:iso}",
