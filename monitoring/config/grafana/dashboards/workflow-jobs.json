      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "avg_duration": true, "count": true }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://127.0.0.1:9103/api/avg-step-duration?category=${category}&repo=${repo_filter}&workflow_name=${workflow_name}&job_type=${job_type}&search=${search:percentencode}&since=${__from:date:iso}&until=${__to:date:iso}",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "",
          "columns": [
            { "selector": "step", "text": "step", "type": "string" },
            { "selector": "avg_duration_s", "text": "avg_duration_s", "type": "number" },
            { "selector": "avg_duration", "text": "avg_duration", "type": "string" },
            { "selector": "count", "text": "count", "type": "number" }
          ]
