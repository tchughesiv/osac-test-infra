    {
      "title": "Recent Runs",
      "description": "All recent workflow runs with status, duration, trigger type, and links. Click column headers to sort.",
      "type": "table",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 29 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "workflow-api" },
      "fieldConfig": {
        "defaults": {},
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "status" },
            "properties": [
              { "id": "displayName", "value": "Status" },
              { "id": "custom.width", "value": 100 },
              { "id": "mappings", "value": [
                { "options": { "success": { "color": "green", "text": "Success" }, "failure": { "color": "red", "text": "Failed" }, "cancelled": { "color": "orange", "text": "Cancelled" }, "queued": { "color": "purple", "text": "Queued" }, "in_progress": { "color": "blue", "text": "Running" } }, "type": "value" }
              ]},
              { "id": "custom.cellOptions", "value": { "mode": "gradient", "type": "color-background" } },
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }] } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "repo" },
            "properties": [
              { "id": "displayName", "value": "Repository" },
              { "id": "custom.width", "value": 160 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "workflow" },
            "properties": [
              { "id": "displayName", "value": "Workflow" },
              { "id": "custom.width", "value": 180 },
              { "id": "links", "value": [{ "title": "Open in GitHub", "url": "${__data.fields.url}", "targetBlank": true }] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "branch" },
            "properties": [
              { "id": "displayName", "value": "Branch" },
              { "id": "custom.width", "value": 150 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "trigger" },
            "properties": [
              { "id": "displayName", "value": "Trigger" },
              { "id": "custom.width", "value": 150 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "pr_display" },
            "properties": [
              { "id": "displayName", "value": "PR" },
              { "id": "custom.width", "value": 70 },
              { "id": "links", "value": [
                { "title": "Open PR", "url": "${__data.fields.pr_url}", "targetBlank": true },
                { "title": "Filter this dashboard by this PR", "url": "/d/osac-workflow-jobs/osac-ci-workflow-jobs?orgId=1&from=${__from}&to=${__to}&var-search=${__value.raw:percentencode}&var-category=${category:percentencode}&var-repo_filter=${repo_filter:percentencode}&var-workflow_name=${workflow_name:percentencode}&var-status_filter=${status_filter:percentencode}&var-job_type=${job_type:percentencode}&var-merge_similar=${merge_similar:percentencode}", "targetBlank": false }
              ] }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "duration" },
            "properties": [
              { "id": "displayName", "value": "Duration" },
              { "id": "custom.width", "value": 100 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "actor" },
            "properties": [
              { "id": "displayName", "value": "Actor" },
              { "id": "custom.width", "value": 120 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "failed_step" },
            "properties": [
              { "id": "displayName", "value": "Failed Step" },
              { "id": "custom.width", "value": 250 },
              { "id": "custom.cellOptions", "value": { "type": "auto" } }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "created_at" },
            "properties": [
              { "id": "displayName", "value": "Started" },
              { "id": "custom.width", "value": 150 }
            ]
          },
          {
            "matcher": { "id": "byName", "options": "id" },
            "properties": [{ "id": "custom.hidden", "value": true }]
          },
          {
            "matcher": { "id": "byName", "options": "conclusion" },
            "properties": [{ "id": "custom.hidden", "value": true }]
