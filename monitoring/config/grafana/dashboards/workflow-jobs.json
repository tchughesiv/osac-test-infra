    {
      "title": "Results by Workflow",
      "description": "Stacked bars: success (green), failure (red), cancelled (orange) per workflow.",
      "type": "barchart",
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "workflow-api" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "decimals": 0,
          "custom": {
            "fillOpacity": 90,
            "stacking": { "mode": "normal", "group": "A" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "Success" }, "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Failed" }, "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }] },
          { "matcher": { "id": "byName", "options": "Cancelled" }, "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }] }
        ]
      },
      "options": {
        "orientation": "vertical",
        "barWidth": 0.7,
        "groupWidth": 0.7,
        "stacking": "normal",
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" },
        "xTickLabelRotation": 0,
        "showValue": "always"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "total": true,
              "success_rate": true
            },
            "renameByName": {
              "workflow": "Workflow",
              "success": "Success",
              "failure": "Failed",
              "cancelled": "Cancelled"
            },
            "indexByName": {
              "workflow": 0,
              "success": 1,
              "failure": 2,
              "cancelled": 3
            }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://127.0.0.1:9103/api/counts-by-workflow?category=${category}&repo=${repo_filter}&workflow_name=${workflow_name}&job_type=${job_type}&merge_similar=${merge_similar}&search=${search:percentencode}&since=${__from:date:iso}&until=${__to:date:iso}",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "",
          "columns": [
            { "selector": "workflow", "text": "workflow", "type": "string" },
            { "selector": "success", "text": "success", "type": "number" },
            { "selector": "failure", "text": "failure", "type": "number" },
            { "selector": "cancelled", "text": "cancelled", "type": "number" },
            { "selector": "total", "text": "total", "type": "number" },
            { "selector": "success_rate", "text": "success_rate", "type": "number" }
          ]
        }
      ]
    },
    {
      "title": "Success Rate by Workflow",
      "type": "bargauge",
      "gridPos": { "h": 5, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "workflow-api" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "green", "value": 0.8 }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/success_rate/", "values": true },
        "showUnfilled": true,
        "valueMode": "color",
        "namePlacement": "auto"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "success": true,
              "failure": true,
              "cancelled": true,
              "total": true
            },
            "renameByName": {}
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://127.0.0.1:9103/api/counts-by-workflow?category=${category}&repo=${repo_filter}&workflow_name=${workflow_name}&job_type=${job_type}&merge_similar=${merge_similar}&search=${search:percentencode}&since=${__from:date:iso}&until=${__to:date:iso}",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "",
          "columns": [
            { "selector": "workflow", "text": "workflow", "type": "string" },
            { "selector": "success", "text": "success", "type": "number" },
            { "selector": "failure", "text": "failure", "type": "number" },
            { "selector": "cancelled", "text": "cancelled", "type": "number" },
            { "selector": "total", "text": "total", "type": "number" },
            { "selector": "success_rate", "text": "success_rate", "type": "number" }
          ]
        }
      ]
    },
    {
      "title": "Most Failing Steps",
      "description": "Which steps fail most frequently.",
      "type": "piechart",
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 9 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "workflow-api" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "values": ["value", "percent"] },
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/count/", "values": true },
        "pieType": "donut",
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://127.0.0.1:9103/api/failed-steps?category=${category}&repo=${repo_filter}&workflow_name=${workflow_name}&job_type=${job_type}&search=${search:percentencode}&since=${__from:date:iso}&until=${__to:date:iso}",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "",
          "columns": [
            { "selector": "step", "text": "step", "type": "string" },
            { "selector": "count", "text": "count", "type": "number" }
          ]
        }
      ]
    },
    {
      "title": "Failures by Step (over time)",
      "description": "Step failures over time — shows which steps are breaking and when.",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 13 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "bars",
            "fillOpacity": 80,
            "lineWidth": 0,
            "stacking": { "mode": "normal" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "calcs": ["sum"], "displayMode": "table", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "expr": "increase(github_actions_failed_step_total[$__rate_interval])",
          "legendFormat": "{{ step }}",
          "refId": "A"
        }
      ]
    },
    {
      "title": "Avg Duration by Job Type",
      "description": "Average run duration grouped by trigger type: Periodic (cron), Presubmit (PRs), Manual.",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 21 },
      "datasource": { "type": "yesoreyeram-infinity-datasource", "uid": "workflow-api" },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "decimals": 0,
          "color": { "fixedColor": "blue", "mode": "fixed" },
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          }
        },
        "overrides": []
      },
      "options": {
        "displayMode": "gradient",
        "orientation": "horizontal",
        "reduceOptions": { "calcs": ["lastNotNull"], "fields": "/avg_duration_s/", "values": true },
        "showUnfilled": true,
        "namePlacement": "auto"
      },
      "transformations": [
        {
          "id": "organize",
          "options": {
            "excludeByName": { "avg_duration": true, "count": true }
          }
        }
      ],
      "targets": [
        {
          "refId": "A",
          "type": "json",
          "source": "url",
          "format": "table",
          "url": "http://127.0.0.1:9103/api/avg-duration-by-type?category=${category}&repo=${repo_filter}&workflow_name=${workflow_name}&job_type=${job_type}&search=${search:percentencode}&since=${__from:date:iso}&until=${__to:date:iso}",
          "url_options": { "method": "GET", "data": "" },
          "root_selector": "",
          "columns": [
            { "selector": "job_type", "text": "job_type", "type": "string" },
            { "selector": "avg_duration_s", "text": "avg_duration_s", "type": "number" },
            { "selector": "avg_duration", "text": "avg_duration", "type": "string" },
            { "selector": "count", "text": "count", "type": "number" }
          ]
        }
      ]
    },
